# ========================================
# CONFIGURAÇÃO DO BOT TÉCNICO
# ========================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo e renomeie para .env
# 2. Preencha os valores abaixo
# 3. NUNCA commite o arquivo .env no git!
#
# ========================================

# ========================================
# TELEGRAM BOT
# ========================================
# Token do seu bot do Telegram
# Obtenha em: https://t.me/BotFather
# Exemplo: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_TOKEN=seu_token_aqui

# ========================================
# SUPABASE (Banco de Dados)
# ========================================
# URL do seu projeto Supabase
# Exemplo: https://xxxxxxxxxxxxx.supabase.co
SUPABASE_URL=sua_url_supabase_aqui

# Chave anon/public do Supabase
# Encontre em: Project Settings > API > anon public
SUPABASE_KEY=sua_chave_supabase_aqui

# ========================================
# GROQ AI (Opcional)
# ========================================
# Chave da API Groq para OCR e análise de imagens
# Obtenha em: https://console.groq.com
# Se não tiver, deixe em branco (funcionalidades de OCR não funcionarão)
GROQ_API_KEY=sua_chave_groq_aqui

# Modelo Groq a usar (opcional)
# Padrão: qwen/qwen3.6-27b (only model that supports images)
GROQ_MODEL=qwen/qwen3.6-27b

# ========================================
# ADMIN
# ========================================
# Username do admin no Telegram (sem @) para link de contato
ADMIN_USERNAME=seu_username_aqui

# IDs dos administradores separados por vírgula
# ADMIN_IDS=1797158471

# Dia de início do ciclo de produção (padrão: 16)
# CICLO_DIA_INICIO=16

# Dias necessários para ativar turbo (padrão: 24)
# CICLO_DIAS_TURBO=24